# Yohan OS — environment variables (commit only this .example, never .env itself)
# 복사해서 `.env`로 만들고 실제 값을 채운다. `.env`는 .gitignore에 등재됨.

# ────────────────────────────────────────────────────────────
# Notion — 공통
# ────────────────────────────────────────────────────────────
# Notion Internal Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=

# ────────────────────────────────────────────────────────────
# Notion — decisions push (legacy, src/notion/push-decisions.ts)
# ────────────────────────────────────────────────────────────
NOTION_DATABASE_ID=
# 선택 — 기본 "Name" / "SoT Key"
NOTION_TITLE_PROPERTY=
NOTION_PROPERTY_SOT_KEY=
NOTION_PROPERTY_SUMMARY=
NOTION_PROPERTY_SOURCE_PATH=

# ────────────────────────────────────────────────────────────
# Notion — sync_to_notion / sync:notion:records
# ADR·트러블슈팅 → 지식 허브 DB / 세션 로그 → EXECUTION LOG DB
# ────────────────────────────────────────────────────────────
NOTION_KNOWLEDGE_HUB_DB_ID=
NOTION_EXECUTION_LOG_DB_ID=

# 지식 허브 DB 컬럼 이름 (한국어 UI 기본값)
NOTION_KNOWLEDGE_HUB_PROP_TITLE=이름
NOTION_KNOWLEDGE_HUB_PROP_SOT_KEY=SoT Key
NOTION_KNOWLEDGE_HUB_PROP_STATUS=상태
NOTION_KNOWLEDGE_HUB_PROP_CATEGORY=카테고리
# notion_status (Status type) | select  — 기본: notion_status
NOTION_KNOWLEDGE_HUB_STATUS_KIND=notion_status
NOTION_KNOWLEDGE_HUB_STATUS_VALUE=초안
# select | multi_select  — 기본: select
NOTION_KNOWLEDGE_HUB_CATEGORY_KIND=select
NOTION_KNOWLEDGE_HUB_CATEGORY_VALUE=🔧 시스템·아키텍처
# 선택 — SoT 상대 경로 저장용 rich_text 컬럼
NOTION_KNOWLEDGE_HUB_PROP_SOURCE_PATH=

# EXECUTION LOG DB 컬럼 이름
NOTION_EXECUTION_LOG_PROP_TITLE=이름
NOTION_EXECUTION_LOG_PROP_SOT_KEY=SoT Key
NOTION_EXECUTION_LOG_PROP_SOURCE_PATH=

# ────────────────────────────────────────────────────────────
# Notion — OCR pair (src/notion/push-ocr.ts)
# ────────────────────────────────────────────────────────────
NOTION_OCR_RESOURCE_DATABASE_ID=
NOTION_OCR_SUMMARY_DATABASE_ID=
# 컬럼 이름 오버라이드는 src/notion/notion-ocr-env.ts 참조

# ────────────────────────────────────────────────────────────
# Telegram (선택)
# ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ────────────────────────────────────────────────────────────
# OpenAI (선택 — 한국어 요약·title 보조)
# ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
